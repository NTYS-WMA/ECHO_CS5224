APP_NAME=db-manager
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=18087
AUTO_INIT_DB=false

# PostgreSQL (managed service)
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@<rds_endpoint>:5432/<db_name>

# MongoDB (managed service)
MONGODB_URI=mongodb+srv://<mongo_user>:<mongo_password>@<cluster>/<db_name>?retryWrites=true&w=majority
MONGODB_DATABASE=<db_name>
MONGO_PROFILE_COLLECTION=user_additional_profile

# Security
AUTH_ENABLED=true
API_KEY=<shared_service_api_key>
ADMIN_API_KEY=<admin_only_api_key>

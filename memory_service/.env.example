# DeepSeek API Configuration (official)
DEEPSEEK_API_KEY=

# VolcEngine DeepSeek API Configuration (optional; takes priority over official DeepSeek if set)
VOLCENGINE_DEEPSEEK_API_KEY=
VOLCENGINE_DEEPSEEK_ENDPOINT_ID=
VOLCENGINE_DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# OpenAI API Configuration (for embeddings)
OPENAI_API_KEY=

# Doubao API Configuration (for embeddings)
DOUBAO_API_KEY=

# Qwen API Configuration (for embeddings)
DASHSCOPE_API_KEY=

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_COLLECTION_NAME=memories
EMBEDDING_MODEL_DIMS=1536

# MongoDB Configuration (for UserProfile)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=mem0

# MainService Configuration (for cold start)
# Used to fetch initial user profile data when user first accesses the memory service
# Leave empty to disable cold start (cold start is also a no-op until MainService implements the endpoint)
MAINSERVICE_BASE_URL=http://mainservice:8080

# History Database Path
HISTORY_DB_PATH=/app/history/history.db

# AI Generation Service (optional LLM routing)
# USE_GENERATION_SERVICE=true routes all LLM calls through ai_generation_service (Bedrock/Claude)
# instead of calling DeepSeek directly. Falls back to DeepSeek if service is unavailable.
USE_GENERATION_SERVICE=false
AI_GENERATION_SERVICE_URL=http://localhost:8003

# Logging Configuration
# LOG_LEVEL: Control logging verbosity
#   - INFO: Basic request/response logging (default)
#   - DEBUG: Detailed request/response data, query params, LLM prompts/responses
LOG_LEVEL=INFO
# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Service URLs ─────────────────────────────────────────
# Memory Service (MyMem0) — http://localhost:18088
MEMORY_SERVICE_URL=http://localhost:18088

# User Profile Service (served by Memory Service — same port)
USER_PROFILE_SERVICE_URL=http://localhost:18088

# Relationship Service
RELATIONSHIP_SERVICE_URL=http://localhost:18089

# AI Generation Service
AI_GENERATION_SERVICE_URL=http://localhost:8003

# Conversation Persistence Store
CONVERSATION_STORE_URL=http://localhost:8004

# DB Manager (Chen Jiajin) — stores messages + users for relationship scoring
DB_MANAGER_URL=http://localhost:18087

# ── App Settings ─────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Set to true to use mock responses for all downstream services.
# Useful for local testing when other services are not running.
MOCK_SERVICES=true

# ── Orchestrator Tuning ──────────────────────────────────
# Number of recent messages to fetch for short-term context
SHORT_TERM_MESSAGE_LIMIT=12

# Number of long-term memory entries to retrieve
LONG_TERM_MEMORY_LIMIT=5

# Conversation length (message count) that triggers summarization
SUMMARIZATION_THRESHOLD=50

# ── AI Generation Defaults ───────────────────────────────
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=200
